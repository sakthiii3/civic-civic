generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./prisma/dev.db"
}

model Department {
  id        String      @id @default(cuid())
  name      String
  code      String      @unique
  createdAt DateTime    @default(now())
  reports   Report[]
  staff     StaffUser[]
}

model StaffUser {
  id           String                @id @default(cuid())
  email        String                @unique
  passwordHash String
  name         String
  role         String                @default("STAFF")
  departmentId String?
  createdAt    DateTime              @default(now())
  statusNotes  ReportStatusHistory[]
  department   Department?           @relation(fields: [departmentId], references: [id])
}

model Report {
  id            String                @id @default(cuid())
  trackingCode  String                @unique
  title         String
  description   String
  category      String
  urgency       String                @default("MEDIUM")
  status        String                @default("SUBMITTED")
  lat           Float
  lng           Float
  address       String?
  photoPath     String?
  voiceNotePath String?
  citizenName   String?
  citizenPhone  String?
  citizenEmail  String?
  departmentId  String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  department    Department            @relation(fields: [departmentId], references: [id])
  history       ReportStatusHistory[]

  @@index([status])
  @@index([category])
  @@index([departmentId])
  @@index([createdAt])
}

model ReportStatusHistory {
  id            String       @id @default(cuid())
  reportId      String
  status        String
  note          String?
  publicMessage String?
  staffId       String?
  createdAt     DateTime     @default(now())
  staff         StaffUser?   @relation(fields: [staffId], references: [id])
  report        Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}



