generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Department {
  id        String      @id @default(cuid())
  name      String
  code      String      @unique
  createdAt DateTime    @default(now())
  reports   Report[]
  staff     StaffUser[]
}

model StaffUser {
  id           String                @id @default(cuid())
  email        String                @unique
  passwordHash String
  name         String
  role         StaffRole             @default(STAFF)
  departmentId String?
  createdAt    DateTime              @default(now())
  statusNotes  ReportStatusHistory[]
  department   Department?           @relation(fields: [departmentId], references: [id])
}

model Report {
  id            String                @id @default(cuid())
  trackingCode  String                @unique
  title         String
  description   String
  category      IssueCategory
  urgency       Urgency               @default(MEDIUM)
  status        ReportStatus          @default(SUBMITTED)
  lat           Float
  lng           Float
  address       String?
  photoPath     String?
  voiceNotePath String?
  citizenName   String?
  citizenPhone  String?
  citizenEmail  String?
  departmentId  String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  department    Department            @relation(fields: [departmentId], references: [id])
  history       ReportStatusHistory[]

  @@index([status])
  @@index([category])
  @@index([departmentId])
  @@index([createdAt])
}

model ReportStatusHistory {
  id            String       @id @default(cuid())
  reportId      String
  status        ReportStatus
  note          String?
  publicMessage String?
  staffId       String?
  createdAt     DateTime     @default(now())
  staff         StaffUser?   @relation(fields: [staffId], references: [id])
  report        Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

enum IssueCategory {
  POTHOLE
  STREETLIGHT
  TRASH
  WATER_LEAK
  PARK_MAINTENANCE
  OTHER
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
}

enum ReportStatus {
  SUBMITTED
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum StaffRole {
  ADMIN
  STAFF
}
